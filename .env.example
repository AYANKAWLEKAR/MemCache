# Memory-Cache Configuration
# Copy to .env and replace placeholder values

# API Keys (comma-separated for multiple)
API_KEYS=dummy-api-key-123

# L1 Redis
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL_SECONDS=86400
REDIS_MAX_MESSAGES_PER_SESSION=200

# L2 PostgreSQL
POSTGRES_URL=postgresql://memcache:memcache@localhost:5432/memcache

# L3 Neo4j
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dummy-neo4j-password

# Summarization (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Embedding model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# spaCy model (run: python -m spacy download en_core_web_sm)
SPACY_MODEL=en_core_web_sm
